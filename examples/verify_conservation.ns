-- Test Z3 verification of the money conservation law
-- This is the core use case: proving that constraints are consistent

ns conservation

fn transfer(from_balance: Int, to_balance: Int, amount: Int) -> Int
  require amount > 0
  require from_balance >= amount
  ensure (from_balance - amount) + (to_balance + amount) == from_balance + to_balance
  from_balance - amount
