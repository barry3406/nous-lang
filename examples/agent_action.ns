-- ============================================================
-- Nous Example: AI Agent Action Layer
-- The killer use case — replacing Python/JS glue code
-- in agentic systems with verified, constraint-checked flows
-- ============================================================

ns agent.actions

-- ── Types ────────────────────────────────────────────────

type SearchQuery = Text
type Budget = Int where self >= 0

entity SearchResult
  url : Text
  title : Text
  score : Int

-- ── Agent Planning State Machine ─────────────────────────

state AgentTask
  Pending -[plan]-> Planning
  Planning -[approve]-> Executing
  Planning -[reject]-> Failed
  Planning -[replan]-> Planning
  Executing -[complete]-> Completed
  Executing -[error]-> Planning
  Executing -[timeout]-> Failed

-- ── Tool Functions ───────────────────────────────────────

fn web_search(query: Text, max_results: Int) -> Result[Int, Text]
  require max_results > 0
  require max_results <= 20
  effect Http.request
  Ok(max_results)

fn call_llm(prompt: Text, budget: Budget) -> Result[Int, Text]
  require budget > 0
  effect Http.request
  if budget >= 10 then Ok(budget - 10) else Err("budget exhausted")

-- ── Agent Flow ───────────────────────────────────────────

flow research(question: Text, budget: Budget) -> Result[Int, Text]
  require budget > 0
  effect Http.request

  step search =
    web_search(question, 10)?
    rollback: nothing

  step analyze =
    let count = search_result
    if count > 0 then Ok(count) else Err("no results")
    rollback: nothing

  step synthesize =
    let relevant = analyze_result
    call_llm(question, budget)?
    rollback: nothing

-- ── Entry Point ──────────────────────────────────────────

main with [ProductionHandler]
  let result = research("what is nous", 100)
  match result
    Ok(remaining) -> remaining
    Err(msg) -> 0
