-- A simple runnable Nous program

ns demo

fn add(a: Int, b: Int) -> Int
  a + b

fn factorial(n: Int) -> Int
  if n <= 1 then 1 else n * factorial(n - 1)

fn is_even(n: Int) -> Bool
  (n % 2) == 0

main with [ProductionHandler]
  let x = add(3, 4)
  let y = factorial(5)
  let even = is_even(y)
  y
