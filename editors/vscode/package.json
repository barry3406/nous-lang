{
  "name": "nous-lang",
  "displayName": "Nous Language",
  "description": "Language support for Nous — constraint synthesis, Z3 verification, state machines",
  "version": "0.1.0",
  "publisher": "nous",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:nous"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "nous",
        "aliases": [
          "Nous",
          "nous"
        ],
        "extensions": [
          ".ns"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "nous",
        "scopeName": "source.nous",
        "path": "./syntaxes/nous.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.115.0",
    "typescript": "^5.0.0",
    "vscode-languageclient": "^9.0.0"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  }
}
